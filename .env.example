# Server
HOST=127.0.0.1
PORT=4173
NODE_ENV=production
LOG_LEVEL=info

# Request limits
REQUEST_BODY_LIMIT_BYTES=1000000
EXTERNAL_FETCH_TIMEOUT_MS=8000

# Movie data APIs
OMDB_API_KEY=your_omdb_key_here
TMDB_API_KEY=your_tmdb_key_here
TMDB_REGION=US

# Fast2SMS (for phone OTP login — India)
FAST2SMS_API_KEY=your_fast2sms_api_key_here

# Email — Option 1: Resend (recommended — free tier, no SMTP server needed)
# Sign up at https://resend.com and create an API key.
RESEND_API_KEY=re_your_api_key_here

# Email — Option 2: SMTP (Gmail, SendGrid, Mailgun, etc.)
# Set SMTP_HOST to use this instead of Resend. Resend takes priority if both are set.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM=Movie Buddy <noreply@moviebuddy.app>

# HTTPS — native TLS (optional — use Caddyfile for auto Let's Encrypt instead)
# SSL_KEY_PATH=/etc/letsencrypt/live/yourdomain.com/privkey.pem
# SSL_CERT_PATH=/etc/letsencrypt/live/yourdomain.com/fullchain.pem
# HTTPS_PORT=443

# Web Push (VAPID keys — generate with: npx web-push generate-vapid-keys)
PUSH_VAPID_SUBJECT=mailto:you@moviebuddy.app
PUSH_VAPID_PUBLIC_KEY=
PUSH_VAPID_PRIVATE_KEY=

# OAuth providers (optional — app works with demo sign-in without these)
GOOGLE_CLIENT_ID=
MICROSOFT_CLIENT_ID=
MICROSOFT_AUTHORITY=https://login.microsoftonline.com/common
APPLE_CLIENT_ID=
APPLE_REDIRECT_URI=

# Turso cloud database (use https:// not libsql:// — libsql uses a WebSocket that Turso drops on idle)
TURSO_DATABASE_URL=https://your-db-name.turso.io
TURSO_AUTH_TOKEN=your_turso_auth_token

# Admin dashboard (email of the user who can access /api/admin/stats)
ADMIN_EMAIL=you@example.com

# Background scheduler (milliseconds between sweeps)
REMINDER_SCHEDULER_INTERVAL_MS=60000
